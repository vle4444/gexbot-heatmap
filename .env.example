# Copy this file to `.env` and fill in your values.
# `.env` is gitignored — never commit your real key.

# Your GexBot API key (format: gexbot_custom_xxxx).
# The server injects this into outbound requests server-side;
# the browser never sees it.
GEXBOT_API_KEY=

# Port the local server listens on. Default: 3001.
# PORT=3001
